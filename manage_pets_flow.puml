@startuml Manage Pets Flow

start

:Admin navigates to pets management page;

:Admin views list of all pets;

:Admin can filter/search pets;

:Admin selects action: create, edit, delete, update status;

if (Create) then
  :Admin fills pet form (user_id, species, breed, estimated_age, gender, color_markings, description, photo, status, location);
  :Submit, validate, create Pet record;
else if (Edit) then
  :Admin edits pet details;
  :Submit, update record;
else if (Delete) then
  :Confirm deletion;
  :Delete record;
else if (Update Status) then
  :Change status (impounded, adoptable, adopted, claimed, unclaimed, unadopted);
  :Update record, set decision_date if applicable;
endif

:Display success message;

stop

@enduml
