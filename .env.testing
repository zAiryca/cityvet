# .env.testing

# 1. APPLICATION ENVIRONMENT
# Tells Laravel this is the testing environment
APP_ENV=testing
APP_DEBUG=true
# !!! ADD THIS LINE to fix the MissingAppKeyException !!!
APP_KEY=base64:2yN8VDxH3vsGqRrkhS7PiXzpPlj7UDEseA9xB9YqDIU=


# 2. DATABASE CONFIGURATION (Crucial Fix)
# Forces Laravel to use MySQL for running tests
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cityvet_test  # MUST match the name of your test database
DB_USERNAME=root
DB_PASSWORD=

# 3. Recommended Settings for Faster/Cleaner Tests
# Prevents actual emails/queue jobs from running, which speeds up tests
MAIL_MAILER=array
QUEUE_CONNECTION=sync
CACHE_STORE=array
SESSION_DRIVER=array
