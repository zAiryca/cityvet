@startuml Manage Pet Registration Flow

start

:User navigates to pet registrations page;

:User views list of their registrations;

:User can create new registration;

:User fills form (pet_name, species, breed, birthday, gender, color_markings, description, photo);

:User submits form;

if (Form validation fails?) then (yes)
  :Display validation errors;
  :Return to form;
else (no)
  :Create new PetRegistration record;
  :Display success message;
endif

:User can edit existing registration;

:User updates form;

:Submit, update record;

:User can delete registration;

:Confirm deletion;

:Delete record;

:Display success messages;

stop

@enduml
